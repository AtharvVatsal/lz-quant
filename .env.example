# LZ-Quant Environment Variables

# ─── React App (lz-dashboard) ──────────────────────────
# These are used by the React frontend deployed on Vercel

# WebSocket URL for the dual.py backend (no trailing slash)
VITE_WS_URL=ws://your-railway-app.railway.app/ws/dashboard

# REST API URL for the dual.py backend (no trailing slash)
VITE_API_URL=https://your-railway-app.railway.app


# ─── dual.py Backend ────────────────────────────────────
# These are used by the Python backend deployed on Railway

# Alpaca API Keys (required for stock trading)
# Get them free at: https://app.alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
