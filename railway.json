{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "aptPackages": ["curl"],
      "pythonVersion": "3.11",
      "installCmd": "pip install -r requirements.txt",
      "buildCmd": "python download_model.py",
      "startCmd": "python dual.py"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
